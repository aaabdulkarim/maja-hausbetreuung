---
import ContentBox from "../components/ContentBox.astro";
import Layout from "../layouts/Layout.astro";


---

<Layout>
  <section class="hero">
    <div class="container">
      <h1>Ihre Immobilie in sicheren Händen</h1>
      <p>Zuverlässige Hausbetreuung während Ihrer Abwesenheit – professionell und vertrauensvoll.</p>
      <a href="#kontakt" class="btn">Jetzt Angebot anfordern</a>
    </div>
  </section>

  <section class="services-scroll">
  <div class="container services-layout">

    <!-- LINKE SEITE -->
    <div class="services-content">
      <div class="service-item" data-image="assets/gartendienst.jpg">
        <h3>Hausbetreuung</h3>
        <p>Regelmäßige Kontrollen und Pflege Ihrer Immobilie.</p>
      </div>

      <div class="service-item" data-image="assets/hausbetreuung-in-wien.jpg">
        <h3>Gartenpflege</h3>
        <p>Rasenmähen, Heckenschnitt und saisonale Pflege.</p>
      </div>

      <div class="service-item" data-image="assets/winterdienst.jpg">
        <h3>Winterdienst</h3>
        <p>Schneeräumung und Streudienst für Ihre Sicherheit.</p>
      </div>

    </div>

    <!-- RECHTE SEITE -->
    <div class="services-visual">
      <div class="sticky-frame">
        <img id="service-image" src="/images/haus.jpg" alt="">
      </div>
    </div>

  </div>
</section>

  <section class="trust">
    <div class="container">
      <h2>Warum wir?</h2>
      <ul>
        <li>✔ Zuverlässig & pünktlich</li>
        <li>✔ Langjährige Erfahrung</li>
        <li>✔ Versicherter Service</li>
        <li>✔ Persönlicher Ansprechpartner</li>
      </ul>
    </div>
  </section>

  <section class="cta" id="kontakt">
    <div class="container">
      <h2>Kontaktieren Sie uns</h2>
      <p>Wir erstellen Ihnen ein unverbindliches Angebot.</p>
      <a href="tel:+43123456789" class="btn">Jetzt anrufen</a>
    </div>
  </section>

  <script type="module">
    const items = document.querySelectorAll(".service-item");
    const image = document.getElementById("service-image");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const newImage = entry.target.dataset.image;
            image.src = newImage; 

            items.forEach(i => i.classList.remove("active"));
            entry.target.classList.add("active");
          }
        });
      },
      {
        threshold: 0.5
      }
    );

    items.forEach((item) => observer.observe(item));
  </script>
</Layout>