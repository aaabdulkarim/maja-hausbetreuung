---
import ContentBox from "../components/ContentBox.astro";
import Hero from "../components/Hero.astro";
import Vorteile from "../components/Vorteile.astro";
import Layout from "../layouts/Layout.astro";

const contentData = [
  {
    dataTitle: "Gartendienst",
    dataImagePath: "assets/gartendienst.jpg",
    dataText: `Ein gepflegter Garten sorgt für einen positiven Gesamteindruck Ihrer Liegenschaft. Mit Erfahrung und Sorgfalt kümmern wir uns um die regelmäßige Pflege Ihrer Grünanlagen.

Unsere Leistungen:

- Rasenmähen
- Hecken- und Strauchschnitt
- Laub- und Mähgutentfernung
- Unkrautbeseitigung
- Reinigung von Wegen und Einfahrten

Auch einmalige Aufträge übernehmen wir gerne.
    `
  },
  {
    dataTitle: "Hausbetreuung",
    dataImagePath: "assets/hausbetreuung-in-wien.jpg",
    dataText: `Wir übernehmen die komplette Betreuung Ihrer Wohnanlage – zuverlässig, gründlich und professionell. Als Meisterbetrieb ersetzen wir die klassische Hausmeisterarbeit und sorgen dafür, dass alles einwandfrei funktioniert.

Unsere Leistungen umfassen unter anderem:

- Stiegenhausreinigung (trocken & nass)
- Reinigung von Gemeinschaftsräumen
- Fenster- und Türpflege
- Lift- und Handlaufreinigung
- Kleinreparaturen wie Glühbirnenwechsel

Auch private Wohnungsreinigung führen wir sorgfältig und effizient durch – damit Sie mehr Zeit für die wichtigen Dinge im Leben haben.`
  },
  {
    dataTitle: "Winterdienst",
    dataImagePath: "assets/winterdienst.jpg",
    dataText: `Im Winter sorgen wir für sichere Wege und Einfahrten. Schnee und Eis stellen ein hohes Risiko dar – wir kümmern uns zuverlässig und rechtzeitig um die nötigen Maßnahmen.

Unser Winterdienst ist von November bis April rund um die Uhr im Einsatz.

Leistungen:

- Schneeräumung
- Streudienst
- Tauwetterkontrolle
- Reinigung am Saisonende

Für Hausverwaltungen, Firmen und Privatkunden – auch einmalige Einsätze sind möglich.`
  },

] 

---

<Layout>
  <section id="hero" class="hero">
  <Hero>

  </section>  

  <section id="leistungen" class="services-scroll">
    <div class="container services-layout">

      <!-- LINKE SEITE -->
      <div class="services-content">
        {contentData.map((item) => (
          <ContentBox 
          title={item.dataTitle}
          imagePath={item.dataImagePath}
          text={item.dataText}>
        </ContentBox> 
        ))}
        
      </div>

      <!-- RECHTE SEITE -->
      <div class="services-visual">
        <div class="sticky-frame">
          <img class="img active" id="img1" src="assets/gartendienst.jpg" alt="">
          <img class="img" id="img2" src="" alt="">

          <div class="image-caption" id="image-caption">
            Gartendienst
          </div>
        </div>
      </div>

    </div>
  </section>

  <section id="warum" class="trust">
    <Vorteile>
      
    </Vorteile>
  </section>

  <section class="cta" id="kontakt">
    <div class="container">
      <h2>Kontaktieren Sie uns</h2>
      <p>Wir erstellen Ihnen ein unverbindliches Angebot.</p>
      <a href="tel:+43123456789" class="btn">Jetzt anrufen</a>
    </div>
  </section>

  <script>
    const items = document.querySelectorAll(".service-item");

    const img1 = document.getElementById("img1");
    const img2 = document.getElementById("img2");

    let current = img1;
    let next = img2;

    const caption = document.getElementById("image-caption");

    const switchImage = (src, title) => {
      if (current.src.includes(src)) return;

      next.src = src;
      
      caption.textContent = title;

      next.classList.add("active");
      current.classList.remove("active");

      // swap references
      [current, next] = [next, current];
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const newImage = entry.target.dataset.image;
            const newTitle = entry.target.querySelector("h3").textContent;
            switchImage(newImage, newTitle);

            items.forEach(i => i.classList.remove("active"));
            entry.target.classList.add("active");
          }
        });
      },
      { threshold: 0.5 }
    );

    items.forEach((item) => observer.observe(item));
  </script>
</Layout>